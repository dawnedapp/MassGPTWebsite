{
  "manifest_version": 3,
  "name": "GPT Mass Deleter",
  "description": "Bulk delete and archive ChatGPT conversations with ease.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/massgpt-logo.svg",
    "48": "icons/massgpt-logo.svg",
    "128": "icons/massgpt-logo.svg"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["engine.js", "ui.js", "content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_title": "GPT Mass Deleter",
    "default_icon": {
      "16": "icons/massgpt-logo.svg",
      "48": "icons/massgpt-logo.svg",
      "128": "icons/massgpt-logo.svg"
    }
  }
}
